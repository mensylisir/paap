    { "key": "NACOS_SERVER_ADDR", "label": "Nacos 地址", "type": "serviceRef", "target": "nacos", "format": "hostPort", "required": true, "default": "nacos:8848" },
    { "key": "NACOS_NAMESPACE", "label": "Nacos 命名空间", "type": "text", "default": "dev" },
