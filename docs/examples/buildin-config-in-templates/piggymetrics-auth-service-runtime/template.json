{
  "key": "piggymetrics-auth-service-runtime",
  "name": "PiggyMetrics auth-service 运行变量",
  "version": "v1",
  "description": "auth-service 组件专用模板，配置 Spring Cloud Config 和依赖服务密码。",
  "framework": "springboot",
  "componentTypes": ["backend"],
  "sortOrder": 242,
  "fields": [
    { "key": "CONFIG_URI", "label": "配置中心地址", "type": "text", "required": true, "default": "http://config" },
    { "key": "EUREKA_URL", "label": "Eureka 地址", "type": "serviceRef", "target": "eureka", "format": "eurekaUrl", "required": true, "default": "http://eureka:8761/eureka/" },
    { "key": "MONGODB_HOST", "label": "MongoDB 地址", "type": "serviceRef", "target": "mongodb", "format": "host", "required": true, "default": "mongodb" },
    { "key": "MONGODB_PORT", "label": "MongoDB 端口", "type": "serviceRef", "target": "mongodb", "format": "port", "required": true, "default": "27017" },
    { "key": "MONGODB_USERNAME", "label": "MongoDB 用户", "type": "text", "default": "root" },
    { "key": "RABBITMQ_HOST", "label": "RabbitMQ 地址", "type": "serviceRef", "target": "rabbitmq", "format": "host", "required": true, "default": "rabbitmq" },
    { "key": "RABBITMQ_PORT", "label": "RabbitMQ 端口", "type": "serviceRef", "target": "rabbitmq", "format": "port", "required": true, "default": "5672" },
    { "key": "RABBITMQ_USERNAME", "label": "RabbitMQ 用户", "type": "text", "default": "user" },
    { "key": "RABBITMQ_PASSWORD", "label": "RabbitMQ 密码", "type": "password", "required": true, "default": "NlmqeV5jVJRRajta" },
    { "key": "CONFIG_SERVICE_PASSWORD", "label": "配置服务密码", "type": "password", "required": true, "default": "cfg-pwd-2026" },
    { "key": "ACCOUNT_SERVICE_PASSWORD", "label": "账户服务密码", "type": "password", "required": true, "default": "account-pwd-2026" },
    { "key": "STATISTICS_SERVICE_PASSWORD", "label": "统计服务密码", "type": "password", "required": true, "default": "statistics-pwd-2026" },
    { "key": "NOTIFICATION_SERVICE_PASSWORD", "label": "通知服务密码", "type": "password", "required": true, "default": "notification-pwd-2026" },
    { "key": "MONGODB_PASSWORD", "label": "MongoDB 密码", "type": "password", "required": true, "default": "nfVgzC7EFd" },
    { "key": "JAVA_TOOL_OPTIONS", "label": "JVM 参数", "type": "text", "default": "-Xms128m -Xmx384m -XX:MaxMetaspaceSize=128m" }
  ],
  "env": [
    { "name": "SPRING_CLOUD_CONFIG_URI", "source": "value", "value": "__TEMPLATE__CONFIG_URI__配置中心地址__DEFAULT__http://config__" },
    { "name": "EUREKA_URL", "source": "value", "value": "__TEMPLATE__EUREKA_URL__Eureka地址__DEFAULT__http://eureka:8761/eureka/__" },
    { "name": "MONGODB_HOST", "source": "value", "value": "__TEMPLATE__MONGODB_HOST__MongoDB地址__DEFAULT__mongodb__" },
    { "name": "MONGODB_PORT", "source": "value", "value": "__TEMPLATE__MONGODB_PORT__MongoDB端口__DEFAULT__27017__" },
    { "name": "MONGODB_USERNAME", "source": "value", "value": "__TEMPLATE__MONGODB_USERNAME__MongoDB用户__DEFAULT__root__" },
    { "name": "RABBITMQ_HOST", "source": "value", "value": "__TEMPLATE__RABBITMQ_HOST__RabbitMQ地址__DEFAULT__rabbitmq__" },
    { "name": "RABBITMQ_PORT", "source": "value", "value": "__TEMPLATE__RABBITMQ_PORT__RabbitMQ端口__DEFAULT__5672__" },
    { "name": "RABBITMQ_USERNAME", "source": "value", "value": "__TEMPLATE__RABBITMQ_USERNAME__RabbitMQ用户__DEFAULT__user__" },
    { "name": "RABBITMQ_PASSWORD", "source": "secret", "refName": "{{secretName}}", "refKey": "RABBITMQ_PASSWORD" },
    { "name": "CONFIG_SERVICE_PASSWORD", "source": "secret", "refName": "{{secretName}}", "refKey": "CONFIG_SERVICE_PASSWORD" },
    { "name": "ACCOUNT_SERVICE_PASSWORD", "source": "secret", "refName": "{{secretName}}", "refKey": "ACCOUNT_SERVICE_PASSWORD" },
    { "name": "STATISTICS_SERVICE_PASSWORD", "source": "secret", "refName": "{{secretName}}", "refKey": "STATISTICS_SERVICE_PASSWORD" },
    { "name": "NOTIFICATION_SERVICE_PASSWORD", "source": "secret", "refName": "{{secretName}}", "refKey": "NOTIFICATION_SERVICE_PASSWORD" },
    { "name": "MONGODB_PASSWORD", "source": "secret", "refName": "{{secretName}}", "refKey": "MONGODB_PASSWORD" },
    { "name": "JAVA_TOOL_OPTIONS", "source": "value", "value": "__TEMPLATE__JAVA_TOOL_OPTIONS__JVM参数__DEFAULT__-Xms128m -Xmx384m -XX:MaxMetaspaceSize=128m__" },
    { "name": "SPRING_CLOUD_CONFIG_USERNAME", "source": "value", "value": "user" },
    { "name": "SPRING_CLOUD_CONFIG_PASSWORD", "source": "secret", "refName": "{{secretName}}", "refKey": "CONFIG_SERVICE_PASSWORD" }
  ],
  "secrets": [
    {
      "name": "{{secretName}}",
      "data": {
        "CONFIG_SERVICE_PASSWORD": "__TEMPLATE__CONFIG_SERVICE_PASSWORD__配置服务密码__DEFAULT__cfg-pwd-2026__",
        "ACCOUNT_SERVICE_PASSWORD": "__TEMPLATE__ACCOUNT_SERVICE_PASSWORD__账户服务密码__DEFAULT__account-pwd-2026__",
        "STATISTICS_SERVICE_PASSWORD": "__TEMPLATE__STATISTICS_SERVICE_PASSWORD__统计服务密码__DEFAULT__statistics-pwd-2026__",
        "NOTIFICATION_SERVICE_PASSWORD": "__TEMPLATE__NOTIFICATION_SERVICE_PASSWORD__通知服务密码__DEFAULT__notification-pwd-2026__",
        "RABBITMQ_PASSWORD": "__TEMPLATE__RABBITMQ_PASSWORD__RabbitMQ密码__DEFAULT__NlmqeV5jVJRRajta__",
        "MONGODB_PASSWORD": "__TEMPLATE__MONGODB_PASSWORD__MongoDB密码__DEFAULT__nfVgzC7EFd__"
      }
    }
  ]
}
