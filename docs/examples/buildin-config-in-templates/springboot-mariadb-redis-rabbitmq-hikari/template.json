{
  "key": "springboot-mariadb-redis-rabbitmq-hikari",
  "name": "Spring Boot + MariaDB + Redis + RabbitMQ",
  "version": "v1",
  "description": "适用于博客、内容管理等依赖 MariaDB、Redis、RabbitMQ 的 Spring Boot 后端。",
  "framework": "springboot",
  "componentTypes": ["backend"],
  "sortOrder": 33,
  "nativeConfigs": [
    { "name": "application.yml", "path": "files/application.yml" }
  ],
  "files": [
    {
      "name": "Spring Boot application.yml",
      "configMapName": "{{configMapName}}",
      "key": "application.yml",
      "recommendedMountPath": "/etc/paap/application.yml"
    }
  ],
  "env": [
    { "name": "SPRING_CONFIG_ADDITIONAL_LOCATION", "source": "value", "value": "file:/etc/paap/application.yml" },
    { "name": "MARIADB_PASSWORD", "source": "secret", "refName": "{{secretName}}", "refKey": "MARIADB_PASSWORD" },
    { "name": "REDIS_PASSWORD", "source": "secret", "refName": "{{secretName}}", "refKey": "REDIS_PASSWORD" },
    { "name": "RABBITMQ_PASSWORD", "source": "secret", "refName": "{{secretName}}", "refKey": "RABBITMQ_PASSWORD" },
    { "name": "JWT_SECRET", "source": "secret", "refName": "{{secretName}}", "refKey": "JWT_SECRET" }
  ],
  "secrets": [
    {
      "name": "{{secretName}}",
      "data": {
        "MARIADB_PASSWORD": "__TEMPLATE__MARIADB_PASSWORD__MariaDB 密码__",
        "REDIS_PASSWORD": "__TEMPLATE__REDIS_PASSWORD__Redis 密码__",
        "RABBITMQ_PASSWORD": "__TEMPLATE__RABBITMQ_PASSWORD__RabbitMQ 密码__",
        "JWT_SECRET": "__TEMPLATE__JWT_SECRET__JWT 密钥__"
      }
    }
  ]
}
