{
  "fields": [
    { "key": "SERVER_PORT", "label": "服务端口", "type": "number", "default": "8080" },
    { "key": "APP_NAME", "label": "应用名称", "type": "text", "default": "springboot-rabbitmq-service" },
    { "key": "POSTGRES_HOST", "label": "PostgreSQL 地址", "type": "serviceRef", "target": "postgresql", "format": "host", "required": true, "default": "postgresql" },
    { "key": "POSTGRES_PORT", "label": "PostgreSQL 端口", "type": "serviceRef", "target": "postgresql", "format": "port", "default": "5432" },
    { "key": "POSTGRES_DATABASE", "label": "数据库名", "type": "text", "default": "orders_db" },
    { "key": "POSTGRES_USERNAME", "label": "数据库用户", "type": "text", "default": "postgres" },
    { "key": "POSTGRES_PASSWORD", "label": "数据库密码", "type": "password", "output": "secret", "required": true },
    { "key": "RABBITMQ_HOST", "label": "RabbitMQ 地址", "type": "serviceRef", "target": "rabbitmq", "format": "host", "required": true, "default": "rabbitmq" },
    { "key": "RABBITMQ_PORT", "label": "RabbitMQ 端口", "type": "serviceRef", "target": "rabbitmq", "format": "port", "default": "5672" },
    { "key": "RABBITMQ_USERNAME", "label": "RabbitMQ 用户", "type": "text", "default": "admin" },
    { "key": "RABBITMQ_PASSWORD", "label": "RabbitMQ 密码", "type": "password", "output": "secret", "required": true },
    { "key": "RABBITMQ_VHOST", "label": "RabbitMQ vhost", "type": "text", "default": "/" }
  ]
}
