{
  "key": "nginx-default-conf",
  "name": "Nginx default.conf",
  "version": "v1",
  "description": "前端静态站点最常用的 Nginx default.conf，支持 SPA fallback、静态资源缓存、健康检查和 API 反代。",
  "framework": "nginx",
  "componentTypes": ["frontend"],
  "sortOrder": 10,
  "nativeConfigs": [
    { "name": "default.conf", "path": "files/default.conf" }
  ],
  "files": [
    {
      "name": "Nginx default.conf",
      "configMapName": "{{configMapName}}",
      "key": "default.conf",
      "recommendedMountPath": "/etc/nginx/conf.d/default.conf"
    }
  ]
}
